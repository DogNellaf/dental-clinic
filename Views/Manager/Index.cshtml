@model List<Review>
@{
    ViewData["Title"] = "Личный кабинет менеджера";
}

<div class="card text-center">
    <div class="card-header">
        Панель управления менеджера
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link active" aria-current="true" asp-controller="Manager" asp-action="Index">Опубликованные</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Manager" asp-action="HiddenReviews">На модерации</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="row">
                <div class="col">Опубликованных отзывов нет</div>
            </div>
        }
        else
        {
            foreach (var review in Model)
            {
                <div class="row mt-3 align-items-center">
                    <div class="col text-start">
                        <span>@review.Text</span>
                        <br>
                        <small class="text-muted">Клиент #@review.ProfileId</small>
                    </div>
                    <div class="col-auto">
                        <form method="post" asp-controller="Manager" asp-action="Hide" asp-route-reviewId="@review.Id">
                            <button type="submit" class="btn btn-secondary btn-sm">Скрыть</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>

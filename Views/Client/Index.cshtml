@model List<Appointment>
@{
    ViewData["Title"] = "Личный кабинет пациента";
}

<div class="card text-center">
    <div class="card-header">
        Личный кабинет пациента
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link active" aria-current="true" asp-controller="Client" asp-action="Index">Больничная карта</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Client" asp-action="Review">Отзыв</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="row">
                <div class="col">
                    Приемы не найдены
                </div>
            </div>
        }
        else
        {
            foreach (var appointment in Model)
            {
                <div class="row mt-3">
                    <div class="col">
                        <span class="bid">
                            Дата
                            <br>
                            <strong>@appointment.StartAt</strong>
                        </span>
                    </div>
                    <div class="col">
                        <span class="ends">
                            Длительность
                            <br>
                            <strong>@appointment.Duration</strong>
                        </span>
                    </div>
                    <div class="col">
                        <span class="ends">
                            <a asp-route-appointmentId="@appointment.Id" asp-controller="Client" asp-action="Appointment" class="btn btn-info">Подробнее</a>
                        </span>
                    </div>
                </div>
            }
        }
    </div>
</div>
@model List<Appointment>
@{
    ViewData["Title"] = "Больничная карта пациента";
    long clientId = ViewBag.ClientId;
}

<div class="card">
    <div class="card-header">
        Больничная карта — пациент #@clientId
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Doctor" asp-action="Index">Текущий приём</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Doctor" asp-action="Appointments">Все приёмы</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <p class="text-muted">У пациента нет приёмов.</p>
        }
        else
        {
            <table class="table table-hover mt-2">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Дата и время</th>
                        <th>Длительность (мин.)</th>
                        <th>Рекомендации</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appt in Model)
                    {
                        <tr>
                            <td>@appt.Id</td>
                            <td>@appt.StartAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@appt.Duration</td>
                            <td>@(string.IsNullOrEmpty(appt.Recommendation) ? "—" : appt.Recommendation)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <a asp-controller="Doctor" asp-action="Index" class="btn btn-secondary mt-3">Назад к текущему приёму</a>
    </div>
</div>

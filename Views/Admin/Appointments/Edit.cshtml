@model Appointment
@{
    ViewData["Title"] = "Панель администратора";
}

<div class="card text-center">
    <div class="card-header">
        Панель администратора
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link active" aria-current="true" asp-controller="Admin" asp-action="Index">Приёмы</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Profiles">Профили</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Reviews">Отзывы</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <form asp-controller="Admin" asp-action="AppointmentUpdate" asp-route-appointmentId="@Model.Id" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mt-4">
                <label asp-for="StaffId" class="form-label">Номер сотрудника</label>
                <input asp-for="StaffId" class="form-control" />
                <span asp-validation-for="StaffId" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <label asp-for="ClientId" class="form-label">Номер клиента</label>
                <input asp-for="ClientId" class="form-control" />
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <label asp-for="StartAt" class="form-label">Время начала</label>
                <input asp-for="StartAt" type="datetime-local" class="form-control" />
                <span asp-validation-for="StartAt" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <label asp-for="Duration" class="form-label">Длительность (мин.)</label>
                <input asp-for="Duration" class="form-control" />
                <span asp-validation-for="Duration" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <label asp-for="Recommendation" class="form-label">Рекомендации</label>
                <textarea asp-for="Recommendation" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Recommendation" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <label asp-for="DurationChangeReason" class="form-label">Причина изменения длительности</label>
                <input asp-for="DurationChangeReason" class="form-control" />
                <span asp-validation-for="DurationChangeReason" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary ms-2">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

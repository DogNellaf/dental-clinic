@model List<Appointment>
@{
    ViewData["Title"] = "Панель администратора";
}

<div class="card text-center">
    <div class="card-header">
        Панель администратора
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link active" aria-current="true" asp-controller="Admin" asp-action="Index">Приёмы</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Profiles">Профили</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Reviews">Отзывы</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="row">
                <div class="col">Приёмы не найдены</div>
            </div>
        }
        else
        {
            foreach (var appointment in Model)
            {
                <div class="row mt-3 align-items-center">
                    <div class="col">
                        <span class="bid">
                            #@appointment.Id — @appointment.StartAt.ToString("dd.MM.yyyy HH:mm")
                            <br>
                            Сотрудник: <strong>@appointment.StaffId</strong> &nbsp;
                            Клиент: <strong>@(appointment.ClientId == 0 ? "—" : appointment.ClientId.ToString())</strong>
                        </span>
                    </div>
                    <div class="col-auto">
                        <a class="btn btn-info btn-sm" asp-route-appointmentId="@appointment.Id" asp-controller="Admin" asp-action="Appointment">Изменить</a>
                    </div>
                    <div class="col-auto">
                        <form method="post" asp-controller="Admin" asp-action="AppointmentDelete" asp-route-appointmentId="@appointment.Id" class="d-inline">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Удалить приём?')">Удалить</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>

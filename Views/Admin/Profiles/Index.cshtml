@model List<Profile>
@{
    ViewData["Title"] = "Панель администратора";
}

<div class="card text-center">
    <div class="card-header">
        Панель администратора
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Index">Приёмы</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" aria-current="true" asp-controller="Admin" asp-action="Profiles">Профили</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Reviews">Отзывы</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col text-end">
                <a class="btn btn-primary" asp-controller="Admin" asp-action="ProfileCreate">Добавить профиль</a>
            </div>
        </div>
        @if (Model.Count == 0)
        {
            <div class="row">
                <div class="col">Пользователи не найдены</div>
            </div>
        }
        else
        {
            foreach (var profile in Model)
            {
                <div class="row mt-3 align-items-center">
                    <div class="col">
                        <strong>@profile.UserName</strong>
                        <br>
                        <span class="text-muted small">
                            @if (profile.IsDoctor) { <span>Медработник</span> }
                            else if (profile.IsManager) { <span>Менеджер</span> }
                            else if (profile.IsAdmin) { <span>Администратор</span> }
                            else { <span>Клиент</span> }
                            @if (!profile.EmailConfirmed) { <span class="text-danger">(заблокирован)</span> }
                        </span>
                    </div>
                    <div class="col-auto">
                        <a class="btn btn-info btn-sm" asp-controller="Admin" asp-action="Profile" asp-route-profileId="@profile.Id">Изменить</a>
                    </div>
                    @if (!profile.IsAdmin)
                    {
                        <div class="col-auto">
                            @if (profile.EmailConfirmed)
                            {
                                <form method="post" asp-controller="Admin" asp-action="Ban" asp-route-profileId="@profile.Id" class="d-inline">
                                    <button type="submit" class="btn btn-warning btn-sm">Заблокировать</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-controller="Admin" asp-action="Unban" asp-route-profileId="@profile.Id" class="d-inline">
                                    <button type="submit" class="btn btn-success btn-sm">Разблокировать</button>
                                </form>
                            }
                        </div>
                        <div class="col-auto">
                            <form method="post" asp-controller="Admin" asp-action="ProfileDelete" asp-route-profileId="@profile.Id" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Удалить профиль?')">Удалить</button>
                            </form>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

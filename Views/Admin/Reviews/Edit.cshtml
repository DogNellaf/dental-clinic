@model Review
@{
    ViewData["Title"] = "Панель администратора";
}

<div class="card text-center">
    <div class="card-header">
        Панель администратора
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Index">Приёмы</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Profiles">Профили</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" aria-current="true" asp-controller="Admin" asp-action="Reviews">Отзывы</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <form asp-controller="Admin" asp-action="ReviewUpdate" asp-route-reviewId="@Model.Id" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mt-4">
                <label asp-for="Text" class="form-label">Текст отзыва</label>
                <textarea asp-for="Text" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Text" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-controller="Admin" asp-action="Reviews" class="btn btn-secondary ms-2">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

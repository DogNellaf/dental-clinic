@model List<Review>
@{
    ViewData["Title"] = "Панель администратора";
}

<div class="card text-center">
    <div class="card-header">
        Панель администратора
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Index">Приёмы</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Profiles">Профили</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" aria-current="true" asp-controller="Admin" asp-action="Reviews">Отзывы</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="row">
                <div class="col">Отзывы не найдены</div>
            </div>
        }
        else
        {
            foreach (var review in Model)
            {
                <div class="row mt-3 align-items-center">
                    <div class="col">
                        <span class="bid">
                            Клиент #@review.ProfileId
                            <br>
                            <strong>@review.Text</strong>
                        </span>
                    </div>
                    <div class="col-auto">
                        @if (review.IsVisible)
                        {
                            <form method="post" asp-controller="Admin" asp-action="HideReview" asp-route-reviewId="@review.Id" class="d-inline">
                                <button type="submit" class="btn btn-secondary btn-sm">Скрыть</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-controller="Admin" asp-action="ShowReview" asp-route-reviewId="@review.Id" class="d-inline">
                                <button type="submit" class="btn btn-success btn-sm">Опубликовать</button>
                            </form>
                        }
                    </div>
                    <div class="col-auto">
                        <a asp-route-reviewId="@review.Id" asp-controller="Admin" asp-action="Review" class="btn btn-info btn-sm">Изменить</a>
                    </div>
                    <div class="col-auto">
                        <form method="post" asp-controller="Admin" asp-action="ReviewDelete" asp-route-reviewId="@review.Id" class="d-inline">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Удалить отзыв?')">Удалить</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>
